<!-- ══════════ SCROLL NARRATIVE ENGINE ══════════ -->
<script>
/* ─── Cursor ─── */
const cur=document.getElementById('cur'),curR=document.getElementById('cur-r');
let mx=0,my=0,rx=0,ry=0;
document.addEventListener('mousemove',e=>{mx=e.clientX;my=e.clientY;cur.style.left=mx+'px';cur.style.top=my+'px';});
(function loop(){rx+=(mx-rx)*.1;ry+=(my-ry)*.1;curR.style.left=rx+'px';curR.style.top=ry+'px';requestAnimationFrame(loop);})();

/* ─── Chapter Definitions ─── */
const CHAPTERS = [
  {
    num:'I', label:'Chapter I — Site Reading',
    title:'The <em>Ground</em><br>is Sacred.',
    body:'Every great building begins not with steel or glass — but with the act of reading the earth. Before a line is drawn, the site speaks.',
    navText:'Chapter I — Foundation'
  },
  {
    num:'II', label:'Chapter II — Footprint',
    title:'The <em>Plan</em><br>Takes Shape.',
    body:'The ground plane is laid. Axes are established. A building stakes its claim on the earth — defining inside from outside, public from private.',
    navText:'Chapter II — Footprint'
  },
  {
    num:'III', label:'Chapter III — Rise',
    title:'Structure<br><em>Ascends.</em>',
    body:'Floor by floor, the skeleton rises. Structural logic made visible — each level a layer of human inhabitation, stacked into the sky.',
    navText:'Chapter III — Rise'
  },
  {
    num:'IV', label:'Chapter IV — Skin',
    title:'Light Finds<br>its <em>Way In.</em>',
    body:'The facade is not decoration — it is the interface between inside and outside. Glass admits light, frames views, breathes with the city.',
    navText:'Chapter IV — Facade'
  },
  {
    num:'V', label:'Chapter V — Section',
    title:'The <em>Cut</em><br>Reveals All.',
    body:'A section cut slices through the building like a scalpel. What was hidden is now legible — the interior life of the architecture exposed.',
    navText:'Chapter V — Section'
  },
  {
    num:'VI', label:'Chapter VI — Light',
    title:'Space is<br><em>Shaped</em> by Light.',
    body:'Light is the architect\'s most powerful material. It slides through glass, traces across surfaces, and transforms space from container to experience.',
    navText:'Chapter VI — Light'
  },
  {
    num:'VII', label:'Chapter VII — Completion',
    title:'The Building<br><em>Lives.</em>',
    body:'Architecture is complete only when inhabited. The building is now a place — a vessel for human life, memory, and aspiration.',
    navText:'Chapter VII — Complete'
  }
];

/* ─── State ─── */
const svg        = document.getElementById('building-svg');
const gridGroup  = document.getElementById('grid-group');
const groundGroup= document.getElementById('ground-group');
const shellGroup = document.getElementById('shell-group');
const floorsGroup= document.getElementById('floors-group');
const glassGroup = document.getElementById('glass-group');
const sectionGroup=document.getElementById('section-group');
const lightGroup = document.getElementById('light-group');
const cutRect    = document.getElementById('cut-rect');
const lightRay   = document.getElementById('light-ray');
const atmo       = document.getElementById('atmo');
const chNum      = document.getElementById('chapter-num');
const copyEl     = document.getElementById('chapter-copy');
const copyLabel  = document.getElementById('copyLabel');
const copyTitle  = document.getElementById('copyTitle');
const copyBody   = document.getElementById('copyBody');
const navChapter = document.getElementById('navChapter');
const progressBar= document.getElementById('progress-bar');
const dots       = document.querySelectorAll('.cdot');
const scrollHint = document.getElementById('scroll-hint');

const groundShadow=document.getElementById('ground-shadow');
const dotApex  =document.getElementById('dot-apex');
const dotEntry =document.getElementById('dot-entry');
const dotWingL =document.getElementById('dot-wing-l');
const dotWingR =document.getElementById('dot-wing-r');
const annotH   =document.getElementById('annot-h');
const annotW   =document.getElementById('annot-w');
const annotN   =document.getElementById('annot-n');

let currentChapter = -1;

/* ─── Chapter Applier ─── */
function applyChapter(ch, progress) {

  /* Update dots */
  dots.forEach((d,i)=>d.classList.toggle('active', i===ch));

  /* Progress bar */
  const totalProgress = (ch + progress) / CHAPTERS.length;
  progressBar.style.width = (totalProgress * 100) + '%';

  /* Nav chapter */
  navChapter.textContent = CHAPTERS[ch].navText;

  /* Chapter number ghost */
  chNum.textContent = CHAPTERS[ch].num;

  /* Hide scroll hint after chapter 0 */
  scrollHint.style.opacity = ch===0 ? '1':'0';

  /* Update copy if chapter changed */
  if(ch !== currentChapter){
    currentChapter = ch;
    copyEl.classList.remove('active');
    setTimeout(()=>{
      copyLabel.textContent = CHAPTERS[ch].label;
      copyTitle.innerHTML   = CHAPTERS[ch].title;
      copyBody.textContent  = CHAPTERS[ch].body;
      copyEl.classList.add('active');
    }, 200);
  }

  /* ── Per-chapter visual state ── */

  /* Chapter 0: bare site — grid fades in */
  gridGroup.style.opacity   = ch >= 0 ? Math.min(progress * 3, 0.8) : '0';

  /* Chapter 1: ground plane */
  groundGroup.style.opacity = ch >= 1 ? '1':'0';
  groundShadow.style.fill   = ch >= 1 ? 'rgba(0,0,0,0.2)':'rgba(0,0,0,0)';
  if(ch===1 && progress > .3){
    document.querySelectorAll('.bld-ground').forEach(e=>e.classList.add('drawn'));
  }

  /* Chapter 2: shell rises — SVG scale Y grows */
  if(ch >= 2){
    shellGroup.style.opacity = '1';
    const scaleY = ch===2 ? 0.3 + progress*0.7 : 1;
    const scaleX = ch===2 ? 0.85 + progress*0.15 : 1;
    svg.style.transform = ch===2
      ? `scaleX(${scaleX}) scaleY(${scaleY}) translateY(${(1-scaleY)*25}%)`
      : '';
    document.querySelectorAll('.bld-shell').forEach(e=>e.classList.add('drawn'));
    floorsGroup.style.opacity = ch >= 2 ? String(Math.min(progress*2,1)):'0';
  } else {
    shellGroup.style.opacity  = '0';
    floorsGroup.style.opacity = '0';
    svg.style.transform = '';
  }

  /* Chapter 3: facade / glass + perspective tilt */
  if(ch >= 3){
    glassGroup.style.opacity = ch===3 ? String(progress) : '1';
    /* Subtle perspective */
    const tilt = ch===3 ? progress*8 : 0;
    svg.style.transform = `perspective(900px) rotateY(${tilt}deg)`;
  } else {
    glassGroup.style.opacity = '0';
    if(ch < 2) svg.style.transform = '';
  }

  /* Chapter 4: section cut — reveal clip rect from bottom */
  if(ch >= 4){
    sectionGroup.style.opacity = '1';
    const cutH  = ch===4 ? Math.max(0, progress) : 1;
    const rectY = 620 - cutH * 480;
    const rectH = cutH * 480;
    cutRect.setAttribute('y', rectY);
    cutRect.setAttribute('height', rectH);
    /* Rotate slightly to show section angle */
    const rot = ch===4 ? -progress*4 : -4;
    svg.style.transform = `perspective(900px) rotateY(${rot}deg)`;
    /* Annotations */
    annotH.classList.toggle('on', progress > .4);
    annotW.classList.toggle('on', progress > .6);
  } else {
    sectionGroup.style.opacity = '0';
    annotH.classList.remove('on');
    annotW.classList.remove('on');
  }

  /* Chapter 5: light shafts + zoom in */
  if(ch >= 5){
    lightGroup.style.opacity = ch===5 ? String(progress) : '1';
    lightRay.style.height = ch===5 ? (progress*80)+'%' : '80%';
    lightRay.style.opacity = ch===5 ? String(progress*.6) : '0.6';
    /* Zoom in */
    const zoom = ch===5 ? 1 + progress*0.35 : 1.35;
    const curRot = ch===4 ? -4 : (ch===5 ? -4 + progress*4 : 0);
    svg.style.transform = `perspective(900px) rotateY(${curRot}deg) scale(${zoom})`;
    /* Atmo brightens */
    atmo.style.background = `radial-gradient(ellipse 80% 70% at 50% 40%,
      rgba(196,163,90,${0.06 + progress*0.1}) 0%,transparent 70%)`;
  } else {
    lightGroup.style.opacity = '0';
    lightRay.style.height = '0%';
    lightRay.style.opacity = '0';
    if(ch < 4) atmo.style.background='';
  }

  /* Chapter 6: full reveal, glow dots, rotate 360 */
  if(ch >= 6){
    const spin  = progress * 8;  /* subtle rotation */
    const scale = 1.35 - progress*0.35; /* zoom back out to full */
    svg.style.transform = `perspective(900px) rotateY(${spin}deg) scale(${scale})`;
    /* Glow dots */
    dotApex.classList.toggle('on',  progress > .2);
    dotEntry.classList.toggle('on', progress > .3);
    dotWingL.classList.toggle('on', progress > .4);
    dotWingR.classList.toggle('on', progress > .4);
    annotN.classList.toggle('on',   progress > .5);
    /* All layers max */
    lightGroup.style.opacity  = '1';
    glassGroup.style.opacity  = '1';
    sectionGroup.style.opacity= '1';
    atmo.style.background = `radial-gradient(ellipse 90% 80% at 50% 40%,
      rgba(196,163,90,0.14) 0%,transparent 70%)`;
  } else {
    if(ch < 5){
      dotApex.classList.remove('on');
      dotEntry.classList.remove('on');
      dotWingL.classList.remove('on');
      dotWingR.classList.remove('on');
      annotN.classList.remove('on');
    }
  }
}

/* ─── Scroll Handler ─── */
function onScroll(){
  const driver  = document.getElementById('scroll-driver');
  const rect    = driver.getBoundingClientRect();
  const total   = driver.offsetHeight - window.innerHeight;
  const scrolled= Math.max(0, -rect.top);
  const t       = Math.min(scrolled / total, 1);  /* 0–1 */

  const N       = CHAPTERS.length;
  const raw     = t * N;
  const ch      = Math.min(Math.floor(raw), N-1);
  const progress= raw - ch;  /* 0–1 within chapter */

  applyChapter(ch, progress);
}

window.addEventListener('scroll', onScroll, {passive:true});
onScroll(); /* init */

/* ─── Post-scroll reveal ─── */
const rvObs = new IntersectionObserver(entries=>{
  entries.forEach(e=>{if(e.isIntersecting)e.target.classList.add('on')});
},{threshold:.1});
document.querySelectorAll('.rv').forEach(el=>rvObs.observe(el));
</script>
