  mo=!mo;
  const nl=document.getElementById('navLinks');
  nl.style.cssText=mo?'display:flex;flex-direction:column;position:fixed;top:65px;left:0;right:0;background:rgba(8,8,8,.97);padding:2rem 1.5rem;gap:1.5rem;z-index:999;border-top:1px solid rgba(200,169,110,.2)':'';
}

// Scroll reveal
const obs=new IntersectionObserver(e=>e.forEach(x=>{if(x.isIntersecting)x.target.classList.add('on')}),{threshold:.1});
document.querySelectorAll('.rv').forEach(el=>obs.observe(el));

// Counters
function animCount(el,t){let c=0;const s=t/(1800/16),tm=setInterval(()=>{c+=s;if(c>=t){c=t;clearInterval(tm);}el.textContent=Math.floor(c);},16);}
const co=new IntersectionObserver(e=>e.forEach(x=>{if(x.isIntersecting&&!x.target.classList.contains('done')){x.target.classList.add('done','counted');animCount(x.target.querySelector('.count'),+x.target.querySelector('.count').dataset.t);}}),{threshold:.5});
document.querySelectorAll('.ctr').forEach(el=>co.observe(el));

// Form
function submitForm(b){b.textContent='✓ Received — We\'ll be in touch within 24 hrs';b.style.cssText='background:#2a5c3f;color:#7ecfa0;letter-spacing:.06em;width:100%;margin-top:.5rem;padding:1rem;font-family:Syne,sans-serif;font-weight:800;font-size:.75rem;text-transform:uppercase;border:none;cursor:none';setTimeout(()=>{b.textContent='Send Enquiry ↗';b.style.cssText='';},5000);}

// Cursor scale on interactive elements
document.querySelectorAll('.clist-item,.feat,.topper,.tcard').forEach(el=>{
  el.addEventListener('mouseenter',()=>dot.style.transform='translate(-50%,-50%) scale(3)');
  el.addEventListener('mouseleave',()=>dot.style.transform='translate(-50%,-50%) scale(1)');
});
</script>
</body>
</html>
